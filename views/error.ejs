<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Error</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: #f8f9fa;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            text-align: center;
            padding: 30px 40px;
            border-radius: 10px;
            background: #ffffff;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        h1 {
            font-size: 3rem;
            margin-bottom: 10px;
            color: #e63946;
        }

        p {
            font-size: 1.1rem;
            margin-bottom: 20px;
        }

        a {
            text-decoration: none;
            color: white;
            background: #457b9d;
            padding: 10px 18px;
            border-radius: 5px;
            transition: 0.3s;
        }

        a:hover {
            background: #1d3557;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1><%= err.statusCode %></h1>
        <p><%= err.message %></p>
        <a href="/listings">Go Back</a>
    </div>

</body>
</html>