<% layout("layouts/boilerplate")
   %>
    <div class="card-container mt-2">
        <h3 class="mb-3">
            <%= listing.title%>
        </h3>

        <div class="show-listing-card mb-3">
            <img src="<%=listing.image.url%>"
                 alt="listing_image">
            <div class="listing-info">
                <p>
                   <b>Owned by </b><i><%= listing.owner.username%></i> 
                </p>
                <p>
                    <%= listing.description%>
                </p>
                <p class="price">&#8377;<%= listing.price.toLocaleString("en-IN")
                        %>/night</p>
                <p>
                    <%= listing.location%>
                </p>
                <p>
                    <%= listing.country%>
                </p>
            </div>

            <% if(currUser && currUser._id.equals(listing.owner._id)) {%>
            <div class="options">
                <a href="/listings/<%=listing._id%>/edit"
                   class="btn btn-dark edit-btn">Edit this listing</a>

                <form method="POST"
                      action="/listings/<%=listing._id%>?_method=DELETE">
                    <button class="btn btn-dark show-btn ">Delete this listing</button>
                </form>
            </div>
            <% } %>
        </div>
    </div>
    <hr class="border border-dark opacity-100">
    <% if(currUser) { %>
        
        <div class="review-form mt-3 mb-3">
        
        <h3>Share your reviews</h3>
        <form action="/listings/<%=listing._id%>/reviews"
              method="POST"
              novalidate
              class="needs-validation">
            <div class="mt-3">
                <label class="form-label" for="rating">Rating</label>
            
                <fieldset class="starability-grow">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />

                    <input type="radio" id="rate1" name="review[rating]" value="1" />
                    <label for="rate1">1 star.</label>

                    <input type="radio" id="rate2" name="review[rating]" value="2" />
                    <label for="rate2">2 stars.</label>

                    <input type="radio" id="rate3" name="review[rating]" value="3" />
                    <label for="rate3">3 stars.</label>

                    <input type="radio" id="rate4" name="review[rating]" value="4" />
                    <label for="rate4">4 stars.</label>

                    <input type="radio" id="rate5" name="review[rating]" value="5" />
                    <label for="rate5">5 stars.</label>

                    <span class="starability-focus-ring"></span>
                 </fieldset>
            </div>
            <div class="mt-3 mb-3">
                <label for="comment"
                       class="form-label">Comment</label>
                <textarea name="review[comment]"
                          id="comment"
                          rows="5"
                          cols="100"
                          class="form-control"
                          required></textarea>
                <div class="invalid-feedback">
                    Please add a valid feedback
                </div>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
        </form>
    </div>
    <hr class="my-4">
    <% } %>
    <p class="fw-semibold fs-5 mt-4 mb-2">All Reviews</p>

    <div class="row g-4">
    <% for(review of listing.reviews){ %>
         <div class="col-md-4">
            <div class="review-card card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div
                            style=" width:35px; height:35px; border-radius:50%; background:#e9ecef; display:flex; align-items:center; justify-content:center; font-size:14px; margin-right:10px;">
                                <%= review.author.username.at(0).toUpperCase() %>
                        </div>
                            <h6 class="mb-0">@<%= review.author.username %></h6>
                    </div>
                        <p class="starability-result card-text" data-rating="<%= review.rating%>"></p>
                    
                    
                    <p class="card-text text-muted mb-3"><%= review.comment %></p>
                       
                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                        <form method="POST"
                            action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE"
                            class="mt-3">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                    <% } %>   
                </div>
            </div>
        </div>
    <% }%>
    </div>